{
  "version": 2,
  "builds": [
    { "src": "api/disambiguate.js", "use": "@vercel/node" },
    { "src": "web/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/disambiguate", "dest": "/api/disambiguate.js" },
    { "src": "/data/(.*)", "dest": "/web/data/$1" },
    { "src": "/", "dest": "/web/index.html" },
    { "src": "/(.+)", "dest": "/web/$1" }
  ]
}
