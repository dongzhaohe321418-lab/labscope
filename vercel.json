{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "web/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/data/(.*)", "dest": "/web/data/$1", "headers": { "Cache-Control": "public, max-age=3600, must-revalidate" } },
    { "src": "/", "dest": "/web/index.html" },
    { "src": "/(.+)", "dest": "/web/$1" }
  ]
}
